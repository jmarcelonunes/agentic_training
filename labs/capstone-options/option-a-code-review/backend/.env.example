# Required
ANTHROPIC_API_KEY=sk-ant-...

# Optional: customize model (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# GitHub webhook integration (optional — only needed if using webhook)
GITHUB_WEBHOOK_SECRET=your-webhook-secret-from-openssl-rand-hex-32
GITHUB_TOKEN=ghp_your-personal-access-token-with-repo-scope

# CORS origins (comma-separated, default: http://localhost:3000)
# ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Rate limit (default: 10/minute)
# RATE_LIMIT=10/minute
